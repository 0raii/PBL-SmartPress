<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_bg"
    android:orientation="vertical">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btnBackGuide"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_head" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="32dp"
            android:layout_toEndOf="@id/btnBackGuide"
            android:text="Panduan Pengguna"
            android:textColor="@color/text_head"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cara Menggunakan Aplikasi"
                android:textColor="@color/primary_blue"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Beranda -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Kontrol Lampu Pintar"
                android:textColor="@color/text_head"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Gunakan tombol ON/OFF untuk mengontrol lampu secara manual dari jarak jauh.\n● Aktifkan mode OTOMATIS agar lampu menyala sendiri saat sensor mendeteksi kondisi gelap.\n● Status 'Terhubung' menunjukkan perangkat ESP32 Anda aktif."
                android:textColor="@color/text_sub"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Monitoring Daya -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Monitoring Daya &amp; kWh"
                android:textColor="@color/text_head"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Di halaman Beranda, Anda dapat melihat penggunaan listrik (kWh) secara real-time.\n● Klik 'Detail' untuk melihat data Voltase, Ampere, dan Watt yang lebih mendalam."
                android:textColor="@color/text_sub"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Laporan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Laporan Penggunaan"
                android:textColor="@color/text_head"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Gunakan menu Laporan untuk melihat statistik harian, mingguan, hingga bulanan.\n● Pantau estimasi biaya listrik Anda agar lebih hemat."
                android:textColor="@color/text_sub"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Keamanan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. Keamanan &amp; Notifikasi"
                android:textColor="@color/text_head"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Aktifkan 'Peringatan Durasi' di Pengaturan untuk mendapatkan notifikasi jika lampu menyala terlalu lama (lebih dari 5 jam)."
                android:textColor="@color/text_sub"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catatan: Pastikan koneksi internet Anda stabil agar sinkronisasi data dengan perangkat berjalan lancar."
                android:textColor="@color/accent_yellow"
                android:textSize="14sp"
                android:textStyle="italic" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
